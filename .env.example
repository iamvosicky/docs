# ─── PDF Conversion Provider ─────────────────────────────────────────────────
# Which service converts DOCX → PDF.
# Options: cloudconvert | gotenberg | none
# When "none", the app falls back to browser print-to-PDF.
PDF_PROVIDER=none

# ─── CloudConvert (recommended for production) ───────────────────────────────
# Sign up at https://cloudconvert.com — free tier: 25 conversions/day
CLOUDCONVERT_API_KEY=
# Set to "true" to use the sandbox API for testing (no real conversions)
CLOUDCONVERT_SANDBOX=false
# Timeout in milliseconds for the full conversion job (default: 120000)
# CLOUDCONVERT_TIMEOUT_MS=120000

# ─── Gotenberg (self-hosted alternative) ─────────────────────────────────────
# Run: docker run -p 3000:3000 gotenberg/gotenberg:8
GOTENBERG_URL=http://localhost:3000
# GOTENBERG_TIMEOUT_MS=60000

# ─── Auth ─────────────────────────────────────────────────────────────────────
# NEXTAUTH_SECRET=
# NEXTAUTH_URL=http://localhost:3000
